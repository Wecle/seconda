# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/seconda
INTERVIEW_AGENT_V2_ENABLED=false
INTERVIEW_AGENT_LEASE_MS=30000
INTERVIEW_AGENT_LEASE_RENEW_MS=10000
INTERVIEW_AGENT_HEARTBEAT_MS=10000
INTERVIEW_AGENT_PROVIDER_IDLE_MS=25000

# Optional live Agent contract input
INTERVIEW_AGENT_TEST_RESUME_VERSION_ID=resume-version-uuid

# Direct AI providers. Primary/fallback models within a tier must share a prefix.
FAST_MODEL_API_KEY=your-fast-tier-provider-key
QUALITY_MODEL_API_KEY=your-quality-tier-provider-key
AI_MODEL_FAST=deepseek/deepseek-v4-flash
AI_MODEL_FAST_FALLBACK=deepseek/deepseek-v4-pro
AI_MODEL_QUALITY=zhipu/glm-5.1
AI_MODEL_QUALITY_FALLBACK=zhipu/glm-4.7
AI_APPROVED_MODELS=deepseek/deepseek-v4-flash,deepseek/deepseek-v4-pro,zhipu/glm-5.1,zhipu/glm-4.7

# Auth.js
AUTH_SECRET=replace-with-a-long-random-string
AUTH_GITHUB_ID=github-oauth-client-id
AUTH_GITHUB_SECRET=github-oauth-client-secret
AUTH_GOOGLE_ID=google-oauth-client-id
AUTH_GOOGLE_SECRET=google-oauth-client-secret

# Vercel Blob
BLOB_READ_WRITE_TOKEN=xxx
